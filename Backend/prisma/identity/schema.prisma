generator client {
  provider = "prisma-client"
  output   = "../../src/generated/identity"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

// Global Account Roles (The base account level)
enum Role {
  ADMIN
  COORDINATOR
  STAFF
}

// Contextual Session Functions (The role they play in a specific match/session)
enum SessionFunction {
  SURVEILLANT
  CORRECTOR
  JURY_MEMBER
  AUDITOR
  ANONYMAT_COMITE // NEW: Dedicated role for handling physical paper anonymization
}

enum SessionStatus {
  DRAFT
  OPEN
  ATTENDANCE_LOCKED
  ANONYMIZED
  CORRECTION_OPEN
  DELIBERATION
  CLOSED
  ARCHIVED
}

enum CandidateStatus {
  REGISTERED
  VALID
  INVALID
}

enum ImportSource {
  CSV
  EXCEL
  API
  MANUAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum AttendanceMethod {
  QR_SCAN
  MANUAL  // coordinator override if needed
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  email                String    @unique
  passwordHash         String
  role                 Role      @default(STAFF)
  isActive             Boolean   @default(true)
  mustChangePassword   Boolean   @default(true)
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  createdBy            String?

  // flat optional info — no sub-profiles
  phoneNumber   String?
  institution   String?
  academicGrade String?
  specialization String?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  // relations
  auditLogs             AuditLog[]
  coordinatedFormations DoctoralFormation[]
  sessionStaff          SessionStaff[]
  importBatches         ImportBatch[]
  recordedAttendances AttendanceRecord[]

  surveillantRoomAssignments RoomSurveillantAssignment[]

  @@map("users")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  payload   Json?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── DOCTORAL FORMATION ───────────────────────────────────────────────────────

model DoctoralFormation {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  department  String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  createdBy   String

  // coordinator fixed at formation creation
  coordinatorId String
  coordinator   User   @relation(fields: [coordinatorId], references: [id])

  specializations FormationSpecialization[]
  sessions        CompetitionSession[]

  @@map("doctoral_formations")
}

// ─── FORMATION SPECIALIZATION ─────────────────────────────────────────────────
// Permanent specializations defined at the formation level
// e.g. "Intelligence Artificielle", "Cybersécurité"
// Sessions pick from these and set their own availableSlots each year

model FormationSpecialization {
  id          String  @id @default(uuid())
  formationId String
  name        String
  code        String
  isActive    Boolean @default(true)

  formation              DoctoralFormation      @relation(fields: [formationId], references: [id])
  sessionSpecializations SessionSpecialization[]

  @@unique([formationId, code])
  @@map("formation_specializations")
}

// ─── COMPETITION SESSION ──────────────────────────────────────────────────────

model CompetitionSession {
  id                 String        @id @default(uuid())
  formationId        String
  academicYear       String
  label              String
  status             SessionStatus @default(DRAFT)
  examDate           DateTime
  resultsDeadline    DateTime?     // auto: examDate + 5 days
  attendanceDeadline DateTime?
  correctionDeadline DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  formation       DoctoralFormation       @relation(fields: [formationId], references: [id])
  specializations SessionSpecialization[]
  subjects        Subject[]
  gradingConfig   GradingConfig?
  candidates      Candidate[]
  importBatches   ImportBatch[]
  sessionRooms    SessionRoom[]
  sessionStaff    SessionStaff[]
  candidateRoomAssignments   RoomCandidateAssignment[]
  surveillantRoomAssignments RoomSurveillantAssignment[]
  attendanceRecords AttendanceRecord[]
  anonymatMappings AnonymatMapping[]

  @@map("competition_sessions")
}

// ─── SESSION SPECIALIZATION ───────────────────────────────────────────────────
// Per-session instance of a formation specialization
// Coordinator sets availableSlots per specialization per year

model SessionSpecialization {
  id                        String @id @default(uuid())
  sessionId                 String
  formationSpecializationId String
  availableSlots            Int

  session                CompetitionSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  formationSpecialization FormationSpecialization @relation(fields: [formationSpecializationId], references: [id])
  candidates             Candidate[]
  sessionRooms           SessionRoom[]

  @@unique([sessionId, formationSpecializationId])
  @@map("session_specializations")
}

// ─── SESSION STAFF ────────────────────────────────────────────────────────────
// Assigns a user a contextual function within a specific session.
// subjectId is nullable — required only when function = CORRECTOR.
// A corrector can be assigned to multiple subjects in the same session
// (one row per subject). Non-corrector functions always have subjectId = null.

model SessionStaff {
  id         String          @id @default(uuid())
  sessionId  String
  userId     String
  function   SessionFunction // non-nullable: a staff record must always have a function
  subjectId  String?         // nullable — set only when function = CORRECTOR
  assignedAt DateTime        @default(now())
  assignedBy String

  session CompetitionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id])
  subject Subject?           @relation(fields: [subjectId], references: [id])

  // Four-column unique key: correctors can be on multiple subjects in the same session,
  // but not twice on the same subject. Non-correctors are unique on (sessionId, userId, function, NULL).
  @@unique([sessionId, userId, function, subjectId])
  @@map("session_staff")
}

// ─── SUBJECT ──────────────────────────────────────────────────────────────────

model Subject {
  id           String  @id @default(uuid())
  sessionId    String
  name         String
  coefficient  Float
  maxGrade     Float   @default(20)
  minimumGrade Float   @default(10)
  description  String?

  attendanceRecords          AttendanceRecord[]
  anonymatMappings           AnonymatMapping[]
  sessionStaff               SessionStaff[] // correctors assigned to this subject
  session                    CompetitionSession @relation(fields: [sessionId], references: [id])
  roomSurveillantAssignments RoomSurveillantAssignment[]

  @@map("subjects")
}

// ─── GRADING CONFIG ───────────────────────────────────────────────────────────

model GradingConfig {
  id                   String   @id @default(uuid())
  sessionId            String   @unique
  discrepancyThreshold Float    @default(3)
  configuredAt         DateTime @default(now())
  configuredBy         String

  session CompetitionSession @relation(fields: [sessionId], references: [id])

  @@map("grading_configs")
}

// ─── CANDIDATE ────────────────────────────────────────────────────────────────

model Candidate {
  id                 String                 @id @default(uuid())
  sessionId          String

  // 🟢 Updated Comment: Linked strictly by matching the "Specialité Demandée" Excel column text value
  specializationId   String?

  registrationNumber String

  // French name (required)
  firstName          String
  lastName           String

  // Arabic name (from PROGRES)
  firstNameAr        String?
  lastNameAr         String?

  // contact
  email              String?
  phoneNumber        String?
  address            String?

  // identity
  dateOfBirth        String?
  birthPlace         String?
  nationalId         String?

  // degree info
  degreeInstitution  String?
  degreeSpeciality   String? // Raw value from CSV (The candidate's historical university track)
  fieldOfStudy       String?
  cursusType         String? // LMD / CLASSIQUE BAC+5
  graduationYear     Int?

  // 🟢 NEW: Store the exact raw string provided in the "Specialité Demandée" column
  requestedSpeciality String?

  // tie-breaker fields (ranking — ministerial regulation)
  masterClassCategory String?
  masterAverage       Float?  // tie-breaker 2
  bachelorAverage     Float?  // tie-breaker 3

  // system
  status              CandidateStatus        @default(REGISTERED)
  importBatchId       String?
  importedAt          DateTime               @default(now())

  session             CompetitionSession     @relation(fields: [sessionId], references: [id])
  specialization      SessionSpecialization? @relation(fields: [specializationId], references: [id])
  importBatch         ImportBatch?           @relation(fields: [importBatchId], references: [id])
  roomAssignment      RoomCandidateAssignment?
  attendanceRecords   AttendanceRecord[]
  anonymatMappings    AnonymatMapping[]

  @@unique([sessionId, registrationNumber])
  @@map("candidates")
}

// ─── IMPORT BATCH ─────────────────────────────────────────────────────────────

model ImportBatch {
  id               String       @id @default(uuid())
  sessionId        String
  importedBy       String
  source           ImportSource
  fileName         String?
  totalRecords     Int
  validRecords     Int
  invalidRecords   Int
  validationErrors Json?
  importedAt       DateTime     @default(now())

  session        CompetitionSession @relation(fields: [sessionId], references: [id])
  importedByUser User               @relation(fields: [importedBy], references: [id])
  candidates     Candidate[]

  @@map("import_batches")
}

// ─── ROOM ─────────────────────────────────────────────────────────────────────
// Global rooms — created once by admin, reused across sessions

model Room {
  id        String   @id @default(uuid())
  name      String
  capacity  Int
  building  String?
  floor     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  createdBy String

  sessionRooms SessionRoom[]

  @@map("exam_rooms")
}

// ─── SESSION ROOM ─────────────────────────────────────────────────────────────
// Links a global room to a session + specialization
// A room can only appear once per session (one specialization per room)

model SessionRoom {
  id               String    @id @default(uuid())
  sessionId        String
  roomId           String
  specializationId String    // which specialization's candidates sit here
  usedCapacity     Int       @default(0)
  lockedAt         DateTime?
  lockedBy         String?

  session        CompetitionSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  room           Room                  @relation(fields: [roomId], references: [id])
  specialization SessionSpecialization @relation(fields: [specializationId], references: [id])

  candidateAssignments   RoomCandidateAssignment[]
  surveillantAssignments RoomSurveillantAssignment[]
  attendanceRecords AttendanceRecord[]

  // FIX: room appears only once per session — not per specialization
  @@unique([sessionId, roomId])
  @@map("session_rooms")
}

// ─── ROOM CANDIDATE ASSIGNMENT ────────────────────────────────────────────────

model RoomCandidateAssignment {
  id            String @id @default(uuid())
  sessionRoomId String
  candidateId   String @unique // one candidate → one room only
  sessionId     String          // FIX: added for efficient querying and deleteMany
  

  sessionRoom SessionRoom        @relation(fields: [sessionRoomId], references: [id], onDelete: Cascade)
  candidate   Candidate          @relation(fields: [candidateId], references: [id])
  session     CompetitionSession @relation(fields: [sessionId], references: [id])

  @@map("room_candidate_assignments")
}

// ─── ROOM SURVEILLANT ASSIGNMENT ──────────────────────────────────────────────

model RoomSurveillantAssignment {
  id            String @id @default(uuid())
  sessionRoomId String
  userId        String
  sessionId     String // FIX: added for efficient querying
  subjectId     String // NEW: which subject is this surveillant assigned to?

  sessionRoom SessionRoom        @relation(fields: [sessionRoomId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id])
  session     CompetitionSession @relation(fields: [sessionId], references: [id])
  subject     Subject            @relation(fields: [subjectId], references: [id]) // 👈 1. ADD THIS RELATION

  @@unique([sessionRoomId, userId, subjectId]) // 👈 2. UPDATE THIS LINE
  @@map("room_surveillant_assignments")
}


model AttendanceRecord {
  id            String           @id @default(uuid())
  sessionId     String
  candidateId   String           
  sessionRoomId String
  subjectId      String           // NEW: Which subject is this for?
  anonymityCode  String?          @unique // NEW: "copy-002". Unique prevents giving the same copy twice!
  recordedBy    String
  status        AttendanceStatus
  method        AttendanceMethod @default(QR_SCAN)
  recordedAt    DateTime         @default(now())

  session     CompetitionSession @relation(fields: [sessionId], references: [id])
  candidate   Candidate          @relation(fields: [candidateId], references: [id])
  sessionRoom SessionRoom        @relation(fields: [sessionRoomId], references: [id])
  recorder    User               @relation(fields: [recordedBy], references: [id])
  subject        Subject          @relation(fields: [subjectId], references: [id])
  
  // FIX: A candidate can only have one copy/attendance per subject
  @@unique([candidateId, subjectId]) 
  

  @@map("attendance_records")
}




model AnonymatMapping {
  id            String   @id @default(uuid())
  sessionId     String
  subjectId     String
  candidateId   String
  qrCode        String
  anonymousCode String   @unique
  createdAt     DateTime @default(now())

  session   CompetitionSession @relation(fields: [sessionId], references: [id])
  subject   Subject            @relation(fields: [subjectId], references: [id])
  candidate Candidate          @relation(fields: [candidateId], references: [id])

  @@unique([candidateId, subjectId])
  @@map("anonymat_mappings")
}
