

// prisma/correction/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/correction"
}

datasource db {
  provider = "postgresql"
}

enum CopyStatus {
  PENDING         // not yet corrected
  FIRST_DONE      // one corrector submitted
  SECOND_DONE     // both correctors submitted — discrepancy check pending
  DISCREPANCY     // gap > threshold — needs third corrector
  THIRD_DONE      // third corrector submitted
  VALIDATED       // final grade computed
}

enum ResolutionRule {
  MEAN_TWO        // no discrepancy — mean of corrector 1 and 2
  MEAN_CLOSEST    // discrepancy — mean of third + closest of the two
}

model ExamCopy {
  id            String     @id @default(uuid())
  sessionId     String     // reference to identity DB session
  subjectId     String     // reference to identity DB subject
  
  // Notice: candidateId and qrCode are REMOVED. 
  // Correction DB only knows the final anonymous code!
  anonymousCode String     @unique 
  
  status        CopyStatus @default(PENDING)
  createdAt     DateTime   @default(now())

  assignments   CorrectorAssignment[] // 👈 Restored relation
  grades        CorrectionGrade[]
  finalGrade    FinalGrade?

  @@map("exam_copies")
}

// 👈 RESTORED: This is how correctors know what to grade!
model CorrectorAssignment {
  id          String   @id @default(uuid())
  copyId      String
  correctorId String   // userId from identity DB
  sessionId   String
  round       Int      // 1 (Initial parallel) or 2 (Third corrector)
  assignedAt  DateTime @default(now())

  copy ExamCopy @relation(fields: [copyId], references: [id])

  @@unique([copyId, correctorId])  // corrector cannot be on same copy twice
  @@unique([copyId, round])        // prevents assigning 3 correctors to round 1
  @@map("corrector_assignments")
}

model CorrectionGrade {
  id          String   @id @default(uuid())
  copyId      String
  correctorId String   // user ID from identity DB
  grade       Float
  round       Int      // 1 = first, 2 = second, 3 = third
  submittedAt DateTime @default(now())
  note        String?

  copy ExamCopy @relation(fields: [copyId], references: [id])

  // A corrector can only submit one grade per copy
  @@unique([copyId, correctorId]) 
  @@map("correction_grades")
}

model FinalGrade {
  id          String         @id @default(uuid())
  copyId      String         @unique
  finalGrade  Float
  appliedRule ResolutionRule
  computedAt  DateTime       @default(now())

  copy ExamCopy @relation(fields: [copyId], references: [id])

  @@map("final_grades")
}