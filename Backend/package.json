{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --config prisma/identity/prisma.config.ts && prisma generate --config prisma/correction/prisma.config.ts",
    "prisma:push:identity": "prisma db push --config prisma/identity/prisma.config.ts",
    "prisma:push:correction": "prisma db push --config prisma/correction/prisma.config.ts",
    "prisma:migrate:identity": "prisma migrate dev --config prisma/identity/prisma.config.ts",
    "prisma:migrate:correction": "prisma migrate dev --config prisma/correction/prisma.config.ts",
    "prisma:studio:identity": "prisma studio --config prisma/identity/prisma.config.ts",
    "prisma:studio:correction": "prisma studio --config prisma/correction/prisma.config.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.4.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.1.5",
    "morgan": "^1.10.1",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "overrides": {
    "hono": "4.12.7",
    "lodash": "4.17.21",
    "@hono/node-server": "1.19.10"
  }
}
